# Server-only configuration. Never expose the key in browser code.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.6-sol
OPENAI_REASONING_EFFORT=max
OPENAI_TIMEOUT_MS=120000
HOST=127.0.0.1
PORT=4173
# Set to 1 only behind a proxy that removes client-supplied forwarding headers.
TRUST_PROXY=0
